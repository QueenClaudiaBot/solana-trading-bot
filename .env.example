# Solana Bot Configuration
# Copy this file to .env and fill in your values

# Helius RPC endpoint (get from helius.dev)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Your Phantom wallet private key (base58 encoded)
# WARNING: Never share this or commit it to GitHub
WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Bot settings
STARTING_CAPITAL_GBP=150
MAX_POSITION_SIZE_GBP=15
MAX_POSITIONS=3
STOP_LOSS_PERCENT=15
TAKE_PROFIT_PERCENT=30
PORTFOLIO_STOP_PERCENT=30

# Minimum token requirements
MIN_LIQUIDITY_USD=1000000
MIN_TOKEN_AGE_HOURS=24
VOLUME_LOOKBACK_HOURS=4
